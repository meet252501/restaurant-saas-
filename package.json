    "eslint-config-expo": "~10.0.0",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.11",
    "prettier": "^3.7.4",
    "qrcode": "^1.5.4",
    "react-test-renderer": "^19.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@9.12.0"
}
