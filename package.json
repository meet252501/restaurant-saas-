    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@google/generative-ai": "^0.24.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.3",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
