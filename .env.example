# TABLEBOOK: SYSTEM VARIABLES (.env)
# ---------------------------------------------------------
# Copy this to .env and fill in the values.
# ---------------------------------------------------------

# 1. DATABASE (MySQL)
# Get a free MySQL DB at Aiven.io or PlanetScale
DATABASE_URL="mysql://user:pass@host:port/dbname"

# 2. AI ASSISTANT (Gemini)
# Get a free key at https://aistudio.google.com
# Use 'Gemini 1.5 Flash' for the free tier.
GEMINI_API_KEY="your_gemini_key_here"

# 3. WHATSAPP & SMS (MSG91) - OPTIONAL
# If left empty, the app will run in "Manual Mode" (0 cost).
# Staff will see the bill text on-screen to manually send.
MSG91_AUTH_KEY=""
MSG91_WHATSAPP_NUMBER=""

# 4. PHONE PAYMENTS (Razorpay) - INDIA ONLY
# Get keys at https://dashboard.razorpay.com
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# 5. GOOGLE PLACES (Address Lookup)
# Needed for 'Address Auto-fill' in New Bookings.
GOOGLE_PLACES_API_KEY=""

# 6. EXTERNAL ONLINE ORDERS (Optional)
# Webhook key for Zomato/Swiggy integration tests.
ZOMATO_API_KEY="simulated_mode_if_empty"

# ─────────────────────────────────────────────────────────
# 7. GOOGLE SHEETS DATA STORE (Auto-sync all bookings + orders)
# ─────────────────────────────────────────────────────────
# Step 1: Go to https://console.cloud.google.com
# Step 2: Enable "Google Sheets API" and "Google Drive API"
# Step 3: Create a Service Account → Download JSON key
# Step 4: Share your Google Sheet with the service account email
# Step 5: Fill these in:
GOOGLE_SERVICE_ACCOUNT_EMAIL="tablebook@your-gcp-project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPASTE_YOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID="1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms"

# 8. MANAGER EMAIL ALERTS (Auto-send on every booking & order)
# Uses your existing Gmail (EMAIL_FROM + EMAIL_PASSWORD)
# Manager will receive alert on every booking + nightly summary
MANAGER_EMAIL="manager@greenapple.in"
EMAIL_FROM="yourgmail@gmail.com"
EMAIL_PASSWORD="your_gmail_app_password"   # Use App Password, not your real Gmail password
OWNER_PHONE="919876543210"

