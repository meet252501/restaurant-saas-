# ─── Database (SQLite — Local-First) ───────────────────────────
# Data stays on YOUR device. No cloud required.
DATABASE_PATH=./tablebook.db

# ─── Auth & Security ──────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key
OWNER_OPEN_ID=admin_openid_for_testing

# ─── App Configuration ────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Owner Contact (for daily reports) ────────────────────────
OWNER_PHONE=919876543210
OWNER_EMAIL=owner@restaurant.com

# ─── Email Notifications (FREE — Gmail) ──────────────────────
# Use Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_FROM=your.restaurant@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
MANAGER_EMAIL=manager@restaurant.com

# ─── WhatsApp — MSG91 (PREMIUM) ──────────────────────────────
# Sign up: https://msg91.com — Pay-per-message
# MSG91_AUTH_KEY=
# MSG91_WHATSAPP_NUMBER=

# ─── WhatsApp — Twilio (PREMIUM Alternative) ─────────────────
# Sign up: https://twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ─── Google Sheets Backup (PREMIUM) ──────────────────────────
# Free Google Cloud setup (~5 min): see server/_core/googleSheets.ts
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_SHEET_ID=

# ─── Razorpay Payments (PREMIUM) ─────────────────────────────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# ─── Local AI (FREE — runs on your laptop) ───────────────────
# Install Ollama: https://ollama.com
# Then run: ollama run gemma2:2b
# No API key needed — it runs locally!
