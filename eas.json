{
  "cli": {
    "version": ">= 14.2.1"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "apk",
        "env": {
          "EXPO_PUBLIC_API_URL": "https://restaurant-saas-tablebook-api.onrender.com"
        }
      }
    }
  },
  "submit": {
    "production": {}
  }
}
